# Copy this file to .env and fill in the values
# The application reads these environment variables at startup.

# Path to the SQLite database file
DB_PATH=./app.db

# Secret key used to sign JWT tokens — CHANGE THIS in production (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# JWT token lifetime in hours
JWT_EXPIRY_HOURS=8

# Directory where uploaded files are stored
UPLOAD_DIR=./uploads

# Maximum allowed file size in megabytes
MAX_FILE_SIZE_MB=100

# Port the HTTP server listens on
SERVER_PORT=8080

# Frontend origin for CORS (React dev server)
FRONTEND_URL=http://localhost:3000

# Gin mode: debug | release | test
GIN_MODE=debug
