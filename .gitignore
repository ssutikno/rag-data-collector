# Dependencies
node_modules/

# Frontend build output (regenerate with: npm run build in frontend/)
frontend/dist/

# Embedded frontend assets (compiled build artifacts)
backend/ui/

# Go binary
backend/rag-backend.exe
backend/rag-backend.exe~
backend/*.exe

# Temp / scratch files
git_config_check.txt
*.txt.tmp

# SQLite database (contains user data — do not commit)
backend/app.db
backend/*.db
backend/*.db-shm
backend/*.db-wal

# Uploaded files (user content — do not commit)
uploads/
backend/uploads/

# Environment / secrets
.env
*.env
backend/.env
config.local.yaml

# Logs
*.log
backend/*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json

# Go test cache
backend/tmp/
